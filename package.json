{
  "name": "macos-cleaner",
  "packageManager": "bun@1.3.5",
  "type": "module",
  "private": true,
  "license": "UNLICENSED",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "check-types": "turbo check-types",
    "install-cli": "bash scripts/install-whirlpool.sh",
    "build:cli": "bun run --filter @whirlpool/cli build",
    "build:icons": "bun scripts/build-icons.ts",
    "build:clean": "rm -rf .tmp && rm -rf apps/cli/dist",
    "build:macos-app": "bun run build:clean && bun run build:icons && bash scripts/build-macos-app.sh"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "turbo": "^2.9.1",
    "typescript": "^5"
  }
}
