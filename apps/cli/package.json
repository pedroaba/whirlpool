{
  "name": "@whirlpool/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "whirlpool": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/whirlpool",
    "build:bundle": "bun build src/index.ts --outdir dist --target bun",
    "lint": "eslint src",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@whirlpool/cleanup": "workspace:*",
    "@whirlpool/config": "workspace:*",
    "@whirlpool/disk": "workspace:*",
    "@whirlpool/explore": "workspace:*",
    "@whirlpool/format": "workspace:*",
    "@whirlpool/fs-meta": "workspace:*",
    "@whirlpool/logging": "workspace:*",
    "@whirlpool/platform": "workspace:*",
    "@whirlpool/system-apps": "workspace:*",
    "@whirlpool/taxonomy": "workspace:*",
    "cac": "^7.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
